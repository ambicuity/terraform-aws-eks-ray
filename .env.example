# Environment variables for local development and integration testing.
# Copy this file to .env.local and fill in your values.
# .env.local is in .gitignore and will never be committed.

# Required to run AI agent scripts locally or to test Gemini API calls
GEMINI_API_KEY=your-gemini-api-key-here

# Required for GitHub API calls (label management, queue writes, PR creation)
# Minimum scopes: repo (full), workflow (if triggering workflow dispatches)
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Format: owner/repo
GITHUB_REPOSITORY=ambicuity/Terraform-Driven-Ray-on-Kubernetes-Platform
