# Remote State Configuration — Example
#
# Copy this file to backend.tf and fill in your own values.
# Do NOT commit backend.tf with real credentials or bucket names.
#
# This pattern uses S3 for state storage and DynamoDB for state locking.
# Both resources must exist before running `terraform init`.
#
# Create the bucket and table once:
#
#   aws s3api create-bucket \
#     --bucket my-org-ray-platform-tfstate \
#     --region us-east-1
#
#   aws s3api put-bucket-versioning \
#     --bucket my-org-ray-platform-tfstate \
#     --versioning-configuration Status=Enabled
#
#   aws dynamodb create-table \
#     --table-name ray-platform-tfstate-lock \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST

terraform {
  backend "s3" {
    bucket         = "my-org-ray-platform-tfstate"
    key            = "ray-eks-cluster/terraform.tfstate"
    region         = "us-east-1"
    encrypt        = true
    dynamodb_table = "ray-platform-tfstate-lock"
  }
}
